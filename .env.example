# Firebase Web SDK config — public identifiers, NOT secrets.
# Security is enforced by Firestore + Storage rules (firebase/*.rules), not by
# hiding these values. Safe to embed in the production JS bundle.
#
# Get the values from:
#   firebase apps:sdkconfig WEB 1:205913150108:web:37d1938e2c28d8c2dad359 \
#     --project doctorina-test
#
# Copy this file to `.env.local` (gitignored) and fill in the values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=doctorina-test.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=doctorina-test
VITE_FIREBASE_STORAGE_BUCKET=doctorina-test.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=205913150108
VITE_FIREBASE_APP_ID=1:205913150108:web:37d1938e2c28d8c2dad359
